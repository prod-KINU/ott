---
import BaseLayout from '@components/layout/BaseLayout.astro';
import ProjectDetailMobileView from '@components/projects/ProjectDetailMobileView.astro';
import ProjectDetailPanel from '@components/projects/ProjectDetailPanel.astro';
import ProjectGrid from '@components/projects/ProjectGrid.astro';
import { projects } from '@data/projects';
import { site } from '@data/site';
import { dictionary } from '@i18n/index';
---

<BaseLayout title="projects" description={site.description.jp}>
  <section class="projects-page page-frame page-section" aria-labelledby="projects-title">
    <header class="projects-page__header">
      <h1 id="projects-title" class="projects-page__title">
        <span data-lang="jp">{dictionary.jp.projects.title}</span>
        <span data-lang="en">{dictionary.en.projects.title}</span>
      </h1>
      <p class="projects-page__intro text-caption">
        <span data-lang="jp">{dictionary.jp.projects.intro}</span>
        <span data-lang="en">{dictionary.en.projects.intro}</span>
      </p>
    </header>
    <div class="projects-page__body" data-projects-root data-first-project={projects[0]?.slug}>
      <ProjectGrid projects={projects} />
      <div class="projects-page__desktop-detail">
        <ProjectDetailPanel projects={projects} />
      </div>
      <ProjectDetailMobileView projects={projects} />
    </div>
  </section>
  <script>
    import '../scripts/projects.ts';
  </script>
</BaseLayout>

<style>
  .projects-page {
    display: grid;
    gap: var(--spacing-33);
  }

  .projects-page__header {
    max-width: 780px;
    display: grid;
    gap: var(--spacing-15);
  }

  .projects-page__title,
  .projects-page__intro {
    margin: 0;
  }

  .projects-page__title {
    font-family: var(--font-te-40);
    font-size: var(--text-display);
    font-weight: var(--font-weight-thin);
    line-height: var(--leading-display);
  }

  .projects-page__intro {
    color: var(--color-smoke);
  }

  .projects-page__body {
    display: grid;
    grid-template-columns: minmax(320px, 0.92fr) minmax(420px, 1.08fr);
    gap: var(--spacing-66);
    align-items: start;
  }

  .projects-page__desktop-detail {
    position: sticky;
    top: calc(var(--header-height) + var(--spacing-22));
  }

  @media (max-width: 860px) {
    .projects-page__body {
      grid-template-columns: 1fr;
    }

    .projects-page__desktop-detail {
      display: none;
    }
  }
</style>
