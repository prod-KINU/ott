---
import PrimaryNav from './PrimaryNav.astro';
import { media } from '@data/media';

type Props = {
  currentPath: string;
};

const { currentPath } = Astro.props;
---

<button class="menu-toggle" type="button" aria-controls="mobile-menu" aria-expanded="false" data-menu-toggle>
  <span class="menu-toggle__line"></span>
  <span class="menu-toggle__line"></span>
  <span class="visually-hidden">menu</span>
</button>

<div class="mobile-menu" id="mobile-menu" data-mobile-menu hidden>
  <div class="mobile-menu__inner">
    <PrimaryNav currentPath={currentPath} variant="mobile" />
    <img class="mobile-menu__image" src={media.loading[0]} alt="" aria-hidden="true" width="90" height="90" />
  </div>
</div>

<style>
  .menu-toggle {
    width: 42px;
    height: 42px;
    display: none;
    place-items: center;
    gap: 6px;
    border: 1px solid var(--color-steel);
    border-radius: 0;
    background: transparent;
    cursor: pointer;
  }

  .menu-toggle:hover,
  .menu-toggle[aria-expanded="true"] {
    border-color: var(--color-electric-blue);
  }

  .menu-toggle__line {
    width: 18px;
    height: 1px;
    display: block;
    background: currentColor;
  }

  .mobile-menu {
    position: fixed;
    inset: var(--header-height) 0 0;
    z-index: 80;
    background: var(--color-canvas);
    border-top: 1px solid var(--color-steel);
  }

  .mobile-menu__inner {
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: var(--spacing-22);
  }

  .mobile-menu__image {
    width: 72px;
    height: 72px;
    object-fit: contain;
    opacity: 0.72;
  }

  @media (max-width: 760px) {
    .menu-toggle {
      display: grid;
    }
  }
</style>
