---
import PrimaryNav from './PrimaryNav.astro';
import { media } from '@data/media';
import { withBase } from '@utils/paths';

type Props = {
  currentPath: string;
};

const { currentPath } = Astro.props;
---

<button class="menu-toggle" type="button" aria-controls="mobile-menu" aria-expanded="false" data-menu-toggle>
  <img class="menu-toggle__icon" src={withBase('/images/icons/menu.svg')} alt="" width="24" height="24" aria-hidden="true" />
  <span class="visually-hidden">menu</span>
</button>

<div class="mobile-menu" id="mobile-menu" data-mobile-menu hidden>
  <div class="mobile-menu__inner">
    <PrimaryNav currentPath={currentPath} variant="mobile" />
    <img class="mobile-menu__image" src={withBase(media.loading[0])} alt="" aria-hidden="true" width="90" height="90" />
  </div>
</div>

<style>
  .menu-toggle {
    width: 42px;
    height: 42px;
    display: grid;
    place-items: center;
    gap: 6px;
    border: 0;
    border-radius: 0;
    background: transparent;
    cursor: pointer;
  }

  .menu-toggle:hover,
  .menu-toggle[aria-expanded="true"] {
    border-color: var(--color-electric-blue);
  }

  .menu-toggle__icon {
    width: 24px;
    height: 24px;
    display: block;
    object-fit: contain;
  }

  .mobile-menu {
    position: fixed;
    inset: var(--header-height) 0 0;
    z-index: 80;
    background: var(--color-canvas);
    border-top: 1px solid var(--color-steel);
    animation: mobileMenuReveal 180ms ease both;
  }

  .mobile-menu__inner {
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: var(--spacing-22);
  }

  .mobile-menu__image {
    width: 72px;
    height: 72px;
    object-fit: contain;
    opacity: 0.72;
  }

  @keyframes mobileMenuReveal {
    from {
      opacity: 0;
    }

    to {
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-menu {
      animation: none;
    }
  }

</style>
