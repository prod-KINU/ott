---
import { site } from '@data/site';
import { dictionary } from '@i18n/index';
import PrimaryNav from './PrimaryNav.astro';

const currentPath = Astro.url.pathname;
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <a class="site-footer__logo" href="/" aria-label="KINU home">
      <img src={site.logo.light} alt="KINU" width="150" height="40" />
    </a>
    <div class="site-footer__nav">
      <PrimaryNav currentPath={currentPath} variant="footer" />
    </div>
    <address class="site-footer__contact">
      <span>
        <span data-lang="jp">{dictionary.jp.footer.contact}</span>
        <span data-lang="en">{dictionary.en.footer.contact}</span>
      </span>
      <a href={`mailto:${site.contact.email}`}>{site.contact.email}</a>
      <a href={site.contact.instagram} target="_blank" rel="noreferrer">
        <span data-lang="jp">{dictionary.jp.footer.social}</span>
        <span data-lang="en">{dictionary.en.footer.social}</span>
      </a>
    </address>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-graphite);
    color: var(--color-steel);
  }

  .site-footer__inner {
    width: min(100%, var(--content-max));
    margin: 0 auto;
    padding: var(--spacing-33) var(--page-x);
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: var(--spacing-33);
    align-items: start;
  }

  .site-footer__logo {
    width: 112px;
  }

  .site-footer__logo img {
    width: 112px;
    height: auto;
  }

  .site-footer__contact {
    justify-self: end;
    display: grid;
    gap: 8px;
    font-style: normal;
    font-size: var(--text-caption);
    line-height: var(--leading-caption);
    text-align: right;
  }

  .site-footer a:hover {
    color: var(--color-electric-blue);
  }

  @media (max-width: 720px) {
    .site-footer__inner {
      grid-template-columns: 1fr;
    }

    .site-footer__contact {
      justify-self: start;
      text-align: left;
    }
  }
</style>
