---
import { site } from '@data/site';
import { dictionary } from '@i18n/index';
import PrimaryNav from './PrimaryNav.astro';
import { withBase, withoutBase } from '@utils/paths';

const currentPath = withoutBase(Astro.url.pathname);
---

<footer class="site-footer" data-reveal>
  <div class="site-footer__inner">
    <a class="site-footer__logo" href={withBase('/')} aria-label="KINU home">
      <img src={withBase(site.logo.light)} alt="KINU" width="150" height="40" />
    </a>
    <p class="site-footer__copyright">
      <span data-lang="jp">{dictionary.jp.footer.copyright}</span>
      <span data-lang="en">{dictionary.en.footer.copyright}</span>
    </p>
    <div class="site-footer__nav">
      <PrimaryNav currentPath={currentPath} variant="footer" />
    </div>
    <address class="site-footer__contact">
      <a class="site-footer__contact-link site-footer__contact-link--mail" href={`mailto:${site.contact.email}`}>{site.contact.email}</a>
      <a class="site-footer__contact-link site-footer__contact-link--social" href={site.contact.instagram} target="_blank" rel="noreferrer">
        <span data-lang="jp">{dictionary.jp.footer.social}</span>
        <span data-lang="en">{dictionary.en.footer.social}</span>
      </a>
    </address>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-graphite);
    color: var(--color-steel);
  }

  .site-footer__inner {
    width: min(100%, var(--content-max));
    margin: 0 auto;
    padding: 58px var(--page-x);
    display: grid;
    grid-template-columns: 1fr 0.5fr 1fr;
    gap: var(--spacing-66);
    align-items: start;
  }

  .site-footer__logo {
    width: 112px;
    grid-column: 1;
  }

  .site-footer__logo img {
    width: 112px;
    height: auto;
  }

  .site-footer__copyright {
    grid-column: 1;
    margin: var(--spacing-15) 0 0;
    white-space: pre-line;
    font-size: var(--text-caption);
    line-height: var(--leading-caption);
  }

  .site-footer__nav {
    grid-column: 2;
    grid-row: 1 / span 2;
  }

  .site-footer__contact {
    grid-column: 3;
    grid-row: 1 / span 2;
    justify-self: end;
    display: grid;
    gap: var(--spacing-22);
    font-style: normal;
    font-size: var(--text-caption);
    line-height: var(--leading-caption);
    text-align: right;
    padding-left: var(--spacing-66);
    border-left: 1px solid var(--color-smoke);
  }

  .site-footer__contact-link {
    min-height: 34px;
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-15);
  }

  .site-footer__contact-link::before {
    content: "";
    width: 22px;
    height: 18px;
    display: inline-block;
    border: 1px solid currentColor;
  }

  .site-footer__contact-link--social::before {
    width: 22px;
    height: 22px;
  }

  .site-footer a:hover {
    color: var(--color-electric-blue);
  }

  @media (max-width: 720px) {
    .site-footer__inner {
      grid-template-columns: 1fr;
      gap: var(--spacing-33);
    }

    .site-footer__copyright,
    .site-footer__nav,
    .site-footer__contact {
      grid-column: auto;
      grid-row: auto;
      justify-self: start;
      text-align: left;
      padding-left: 0;
      border-left: 0;
    }
  }
</style>
