---
import { site } from '@data/site';
import LanguageSwitch from './LanguageSwitch.astro';
import MobileMenu from './MobileMenu.astro';
import PrimaryNav from './PrimaryNav.astro';

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="site-header__inner">
    <a class="site-header__logo" href="/" aria-label="KINU home">
      <img src={site.logo.dark} alt="KINU" width="150" height="40" />
    </a>
    <div class="site-header__nav">
      <PrimaryNav currentPath={currentPath} />
    </div>
    <div class="site-header__tools">
      <LanguageSwitch />
      <MobileMenu currentPath={currentPath} />
    </div>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    inset: 0 0 auto;
    z-index: 100;
    height: var(--header-height);
    background: var(--color-canvas);
    border-bottom: 1px solid var(--color-steel);
  }

  .site-header__inner {
    width: min(100%, var(--content-max));
    height: 100%;
    margin: 0 auto;
    padding-inline: var(--page-x);
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--spacing-22);
  }

  .site-header__logo {
    width: 112px;
    display: inline-flex;
  }

  .site-header__logo img {
    width: 112px;
    height: auto;
  }

  .site-header__nav {
    justify-self: center;
  }

  .site-header__tools {
    justify-self: end;
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-15);
  }

  @media (max-width: 760px) {
    .site-header__inner {
      grid-template-columns: auto 1fr auto;
    }

    .site-header__nav {
      display: none;
    }

    .site-header__tools {
      grid-column: 3;
    }
  }
</style>
