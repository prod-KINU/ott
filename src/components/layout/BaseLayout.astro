---
import SeoHead from '@components/utility/SeoHead.astro';
import LoadingOverlay from '@components/utility/LoadingOverlay.astro';
import SiteFooter from './SiteFooter.astro';
import SiteHeader from './SiteHeader.astro';
import '@styles/global.css';

type Props = {
  title?: string;
  description?: string;
};

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="ja" data-i18n-lang="jp">
  <head>
    <SeoHead title={title} description={description} />
  </head>
  <body>
    <LoadingOverlay />
    <div class="site-shell">
      <SiteHeader />
      <main class="site-main">
        <slot />
      </main>
      <SiteFooter />
    </div>
    <script>
      import '../../scripts/site.ts';
    </script>
  </body>
</html>
