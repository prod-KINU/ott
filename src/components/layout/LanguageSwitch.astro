---
import { jp } from '@i18n/jp';
---

<div class="language-switch" aria-label={jp.common.langLabel}>
  <button class="language-switch__button is-active" type="button" data-lang-button="jp" aria-pressed="true">JP</button>
  <span class="language-switch__divider" aria-hidden="true">/</span>
  <button class="language-switch__button" type="button" data-lang-button="en" aria-pressed="false">EN</button>
</div>

<style>
  .language-switch {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: var(--text-caption);
    line-height: var(--leading-caption);
    white-space: nowrap;
  }

  .language-switch__button {
    min-height: 34px;
    padding: 0;
    border: 0;
    border-radius: 0;
    background: transparent;
    color: var(--color-smoke);
    cursor: pointer;
    font-weight: var(--font-weight-light);
  }

  .language-switch__button:hover,
  .language-switch__button:focus-visible,
  .language-switch__button.is-active {
    color: var(--color-electric-blue);
  }

  .language-switch__divider {
    color: var(--color-smoke);
  }
</style>
