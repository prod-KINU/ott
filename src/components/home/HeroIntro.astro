---
import { dictionary } from '@i18n/index';
---

<div class="hero-intro">
  <p class="hero-intro__eyebrow text-caption" data-lang="jp">{dictionary.jp.home.eyebrow}</p>
  <p class="hero-intro__eyebrow text-caption" data-lang="en">{dictionary.en.home.eyebrow}</p>
  <h1 id="home-title" class="hero-intro__title">{dictionary.jp.home.title}</h1>
  <p class="hero-intro__text" data-lang="jp">{dictionary.jp.home.intro}</p>
  <p class="hero-intro__text" data-lang="en">{dictionary.en.home.intro}</p>
</div>

<style>
  .hero-intro {
    max-width: 520px;
    display: grid;
    gap: var(--spacing-22);
  }

  .hero-intro__eyebrow {
    margin: 0 0 var(--spacing-33);
    color: var(--color-smoke);
  }

  .hero-intro__title {
    margin: 0;
    font-family: var(--font-te-40);
    font-size: clamp(40px, 8vw, 96px);
    font-weight: var(--font-weight-thin);
    line-height: 0.98;
    letter-spacing: 0;
  }

  .hero-intro__text {
    margin: 0;
    max-width: 31em;
  }
</style>
