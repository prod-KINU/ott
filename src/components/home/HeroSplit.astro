---
import HeroIntro from './HeroIntro.astro';
import HeroMedia from './HeroMedia.astro';
---

<section class="hero-split page-frame page-section" aria-labelledby="home-title">
  <div class="hero-split__intro">
    <HeroIntro />
  </div>
  <div class="hero-split__media">
    <HeroMedia />
  </div>
</section>

<style>
  .hero-split {
    min-height: calc(100svh - var(--header-height));
    display: grid;
    grid-template-columns: minmax(280px, 0.82fr) minmax(360px, 1.18fr);
    gap: var(--spacing-66);
    align-items: center;
  }

  .hero-split__intro {
    align-self: center;
  }

  @media (max-width: 860px) {
    .hero-split {
      min-height: auto;
      grid-template-columns: 1fr;
      gap: var(--spacing-33);
      align-items: start;
    }
  }
</style>
