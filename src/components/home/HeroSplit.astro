---
import HeroIntro from './HeroIntro.astro';
import HeroMedia from './HeroMedia.astro';
---

<section class="hero-split page-frame page-section" aria-labelledby="home-title">
  <div class="hero-split__media">
    <HeroMedia />
  </div>
  <div class="hero-split__intro">
    <HeroIntro />
  </div>
</section>

<style>
  .hero-split {
    min-height: clamp(620px, 48svh, 690px);
    display: grid;
    grid-template-columns: minmax(360px, 1.34fr) minmax(300px, 0.76fr);
    gap: var(--spacing-66);
    align-items: center;
    border-bottom: 1px solid var(--color-steel);
    padding-block: 0;
  }

  .hero-split__intro {
    align-self: center;
  }

  @media (max-width: 860px) {
    .hero-split {
      min-height: auto;
      grid-template-columns: 1fr;
      gap: var(--spacing-33);
      align-items: start;
    }
  }
</style>
