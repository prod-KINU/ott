---
import { dictionary } from '@i18n/index';
import { withBase } from '@utils/paths';

const panels = [
  {
    number: '01',
    icon: 'cube',
    href: '/projects',
    jp: dictionary.jp.home.panels.works,
    en: dictionary.en.home.panels.works
  },
  {
    number: '02',
    icon: 'team',
    href: '/about',
    jp: dictionary.jp.home.panels.team,
    en: dictionary.en.home.panels.team
  },
  {
    number: '03',
    icon: 'mail',
    href: 'mailto:contact@example.com',
    jp: dictionary.jp.home.panels.contact,
    en: dictionary.en.home.panels.contact
  }
];
---

<section class="home-features page-frame" aria-label="home links">
  {
    panels.map((panel) => (
      <article class="home-feature">
        <span class="home-feature__number">{panel.number}</span>
        <div class={`home-feature__icon home-feature__icon--${panel.icon}`} aria-hidden="true">
          <span></span>
        </div>
        <h2 class="home-feature__title">
          <span data-lang="jp">{panel.jp.title}</span>
          <span data-lang="en">{panel.en.title}</span>
        </h2>
        <span class="home-feature__rule" aria-hidden="true"></span>
        <p class="home-feature__text" data-lang="jp">{panel.jp.text}</p>
        <p class="home-feature__text" data-lang="en">{panel.en.text}</p>
        <a class="home-feature__link" href={withBase(panel.href)}>
          <span data-lang="jp">{panel.jp.link}</span>
          <span data-lang="en">{panel.en.link}</span>
          <span aria-hidden="true">→</span>
        </a>
      </article>
    ))
  }
</section>

<style>
  .home-features {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border-bottom: 1px solid var(--color-steel);
  }

  .home-feature {
    min-height: 440px;
    display: grid;
    justify-items: center;
    align-content: start;
    gap: var(--spacing-15);
    padding: 48px var(--spacing-22) var(--spacing-33);
    text-align: center;
    border-right: 1px solid var(--color-steel);
  }

  .home-feature:last-child {
    border-right: 0;
  }

  .home-feature__number {
    justify-self: start;
    font-size: var(--text-caption);
    line-height: var(--leading-caption);
  }

  .home-feature__icon {
    width: 56px;
    height: 56px;
    position: relative;
    margin-top: var(--spacing-15);
  }

  .home-feature__icon--cube {
    border: 1px solid var(--color-ink);
  }

  .home-feature__icon--cube::before,
  .home-feature__icon--cube::after {
    content: "";
    position: absolute;
    border-color: var(--color-ink);
  }

  .home-feature__icon--cube::before {
    inset: 0 auto auto 0;
    width: 56px;
    height: 1px;
    transform: translate(14px, 16px) rotate(-45deg);
    transform-origin: left center;
    background: var(--color-ink);
  }

  .home-feature__icon--cube::after {
    left: 28px;
    top: 27px;
    width: 1px;
    height: 28px;
    background: var(--color-ink);
  }

  .home-feature__icon--team::before,
  .home-feature__icon--team::after {
    content: "";
    position: absolute;
    top: 4px;
    width: 20px;
    height: 20px;
    border: 1px solid var(--color-ink);
  }

  .home-feature__icon--team::before {
    left: 6px;
  }

  .home-feature__icon--team::after {
    right: 6px;
  }

  .home-feature__icon--team span::before,
  .home-feature__icon--team span::after {
    content: "";
    position: absolute;
    bottom: 5px;
    width: 22px;
    height: 26px;
    border: 1px solid var(--color-ink);
    border-bottom: 0;
  }

  .home-feature__icon--team span::before {
    left: 4px;
  }

  .home-feature__icon--team span::after {
    right: 4px;
  }

  .home-feature__icon--mail {
    border: 1px solid var(--color-ink);
  }

  .home-feature__icon--mail::before,
  .home-feature__icon--mail::after {
    content: "";
    position: absolute;
    top: 26px;
    width: 39px;
    height: 1px;
    background: var(--color-ink);
  }

  .home-feature__icon--mail::before {
    left: -2px;
    transform: rotate(38deg);
  }

  .home-feature__icon--mail::after {
    right: -2px;
    transform: rotate(-38deg);
  }

  .home-feature__title {
    margin: var(--spacing-15) 0 0;
    font-size: var(--text-subheading);
    font-weight: var(--font-weight-light);
    line-height: var(--leading-subheading);
  }

  .home-feature__rule {
    width: 44px;
    height: 1px;
    background: var(--color-ink);
  }

  .home-feature__text {
    margin: 0;
    max-width: 250px;
    font-size: var(--text-caption);
    line-height: var(--leading-caption);
  }

  .home-feature__link {
    min-height: 42px;
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-15);
    color: var(--color-electric-blue);
    font-size: var(--text-caption);
    line-height: var(--leading-caption);
  }

  @media (max-width: 760px) {
    .home-features {
      grid-template-columns: 1fr;
    }

    .home-feature {
      min-height: 0;
      border-right: 0;
      border-bottom: 1px solid var(--color-steel);
    }
  }
</style>
