---
import { dictionary } from '@i18n/index';
import { site } from '@data/site';
import { withBase } from '@utils/paths';

const panels = [
  {
    number: '01',
    icon: 'cube',
    href: '/projects',
    jp: dictionary.jp.home.panels.works,
    en: dictionary.en.home.panels.works
  },
  {
    number: '02',
    icon: 'team',
    href: '/about',
    jp: dictionary.jp.home.panels.team,
    en: dictionary.en.home.panels.team
  },
  {
    number: '03',
    icon: 'mail',
    href: `mailto:${site.contact.email}`,
    jp: dictionary.jp.home.panels.contact,
    en: dictionary.en.home.panels.contact
  }
];
---

<section class="home-features page-frame" aria-label="home links" data-reveal>
  {
    panels.map((panel) => (
      <article class="home-feature">
        <span class="home-feature__number">{panel.number}</span>
        <div class={`home-feature__icon home-feature__icon--${panel.icon}`} aria-hidden="true">
          {
            panel.icon === 'cube' && (
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.429 9.75 2.25 12l4.179 2.25m0-4.5 5.571 3 5.571-3m-11.142 0L2.25 7.5 12 2.25l9.75 5.25-4.179 2.25m0 0L21.75 12l-4.179 2.25m0 0 4.179 2.25L12 21.75 2.25 16.5l4.179-2.25m11.142 0-5.571 3-5.571-3" />
              </svg>
            )
          }
          {
            panel.icon === 'team' && (
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
              </svg>
            )
          }
          {
            panel.icon === 'mail' && (
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
              </svg>
            )
          }
        </div>
        <h2 class="home-feature__title">
          <span data-lang="jp">{panel.jp.title}</span>
          <span data-lang="en">{panel.en.title}</span>
        </h2>
        <span class="home-feature__rule" aria-hidden="true"></span>
        <p class="home-feature__text" data-lang="jp">{panel.jp.text}</p>
        <p class="home-feature__text" data-lang="en">{panel.en.text}</p>
        <a class="home-feature__link" href={withBase(panel.href)}>
          <span data-lang="jp">{panel.jp.link}</span>
          <span data-lang="en">{panel.en.link}</span>
          <span aria-hidden="true">→</span>
        </a>
      </article>
    ))
  }
</section>

<style>
  .home-features {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border-bottom: 1px solid var(--color-steel);
  }

  .home-feature {
    min-height: 440px;
    display: grid;
    justify-items: center;
    align-content: start;
    gap: var(--spacing-15);
    padding: 48px var(--spacing-22) var(--spacing-33);
    text-align: center;
    border-right: 1px solid var(--color-steel);
  }

  .home-feature:last-child {
    border-right: 0;
  }

  .home-feature__number {
    justify-self: start;
    font-size: var(--text-caption);
    line-height: var(--leading-caption);
  }

  .home-feature__icon {
    width: 56px;
    height: 56px;
    margin-top: var(--spacing-15);
  }

  .home-feature__icon svg {
    width: 56px;
    height: 56px;
    display: block;
  }

  .home-feature__title {
    margin: var(--spacing-15) 0 0;
    font-size: var(--text-subheading);
    font-weight: var(--font-weight-light);
    line-height: var(--leading-subheading);
  }

  .home-feature__rule {
    width: 44px;
    height: 1px;
    background: var(--color-ink);
  }

  .home-feature__text {
    margin: 0;
    max-width: 250px;
    font-size: var(--text-caption);
    line-height: var(--leading-caption);
  }

  .home-feature__link {
    min-height: 42px;
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-15);
    color: var(--color-electric-blue);
    font-size: var(--text-caption);
    line-height: var(--leading-caption);
  }

  .home-feature__link span[aria-hidden="true"] {
    transition: transform 160ms ease;
  }

  .home-feature__link:hover span[aria-hidden="true"] {
    transform: translateX(4px);
  }

  @media (max-width: 760px) {
    .home-features {
      grid-template-columns: 1fr;
    }

    .home-feature {
      min-height: 0;
      border-right: 0;
      border-bottom: 1px solid var(--color-steel);
    }
  }
</style>
