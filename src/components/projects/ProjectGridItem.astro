---
import type { ProjectItem } from '@data/projects';
import { withBase } from '@utils/paths';

type Props = {
  project: ProjectItem;
  active?: boolean;
};

const { project, active = false } = Astro.props;
---

<a class:list={['project-grid-item', { 'is-active': active }]} href={withBase(`/projects?project=${project.slug}`)} data-project-trigger={project.slug} aria-current={active ? 'true' : undefined}>
  <img class="project-grid-item__image" src={withBase(project.thumbnail)} alt={project.alt.jp} width="700" height="700" data-alt-jp={project.alt.jp} data-alt-en={project.alt.en} />
  <span class="project-grid-item__meta text-caption">{project.date}</span>
  <span class="project-grid-item__title">
    <span data-lang="jp">{project.title.jp}</span>
    <span data-lang="en">{project.title.en}</span>
  </span>
</a>

<style>
  .project-grid-item {
    min-width: 0;
    display: grid;
    gap: 10px;
    color: var(--color-ink);
  }

  .project-grid-item__image {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border: 1px solid var(--color-steel);
  }

  .project-grid-item:hover,
  .project-grid-item.is-active {
    color: var(--color-electric-blue);
  }

  .project-grid-item:hover .project-grid-item__image,
  .project-grid-item.is-active .project-grid-item__image {
    border-color: var(--color-electric-blue);
  }

  .project-grid-item__meta {
    color: var(--color-smoke);
  }

  .project-grid-item__title {
    font-size: var(--text-body);
    line-height: var(--leading-body);
  }
</style>
