---
import type { ProjectItem } from '@data/projects';
import { withBase } from '@utils/paths';
import ProjectLink from './ProjectLink.astro';
import ProjectMeta from './ProjectMeta.astro';

type Props = {
  projects: ProjectItem[];
};

const { projects } = Astro.props;
---

<section class="project-detail-panel" aria-live="polite" data-project-detail-panel>
  {
    projects.map((project, index) => (
      <article class:list={['project-detail', { 'is-active': index === 0 }]} data-project-detail={project.slug} hidden={index !== 0}>
        <img class="project-detail__image" src={withBase(project.mainImage)} alt={project.alt.jp} width="1400" height="950" data-alt-jp={project.alt.jp} data-alt-en={project.alt.en} />
        <div class="project-detail__body">
          <h2 class="project-detail__title">
            <span data-lang="jp">{project.title.jp}</span>
            <span data-lang="en">{project.title.en}</span>
          </h2>
          <span class="project-detail__rule" aria-hidden="true"></span>
          <ProjectMeta project={project} />
          <span class="project-detail__rule" aria-hidden="true"></span>
          <p class="project-detail__description" data-lang="jp">{project.description.jp}</p>
          <p class="project-detail__description" data-lang="en">{project.description.en}</p>
          <ProjectLink href={project.link} />
        </div>
      </article>
    ))
  }
</section>

<style>
  .project-detail-panel {
    min-width: 0;
  }

  .project-detail {
    display: grid;
    gap: var(--spacing-22);
    animation: projectDetailReveal 180ms ease both;
  }

  .project-detail[hidden] {
    display: none;
  }

  .project-detail__image {
    width: 100%;
    height: min(31vw, 360px);
    aspect-ratio: 14 / 9.5;
    object-fit: cover;
    border: 1px solid var(--color-smoke);
    transition: border-color 160ms ease, opacity 180ms ease;
  }

  .project-detail__body {
    display: grid;
    gap: var(--spacing-15);
  }

  .project-detail__title {
    margin: 0;
    font-family: var(--font-te-40);
    font-size: var(--text-heading);
    font-weight: var(--font-weight-thin);
    line-height: var(--leading-heading);
  }

  .project-detail__description {
    margin: 0;
    max-width: 38em;
    font-size: var(--text-caption);
    line-height: var(--leading-caption);
  }

  .project-detail__rule {
    width: 42px;
    height: 1px;
    margin-block: 5px;
    background: var(--color-ink);
  }

  @keyframes projectDetailReveal {
    from {
      opacity: 0;
      transform: translateY(6px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .project-detail {
      animation: none;
    }
  }
</style>
