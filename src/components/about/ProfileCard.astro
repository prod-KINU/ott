---
import type { ProfileItem } from '@data/profiles';
import { withBase } from '@utils/paths';

type Props = {
  profile: ProfileItem;
};

const { profile } = Astro.props;
---

<article class="profile-card">
  <img class="profile-card__image" src={withBase(profile.image)} alt={profile.alt.jp} width="900" height="900" data-alt-jp={profile.alt.jp} data-alt-en={profile.alt.en} />
  <div class="profile-card__body">
    <h2 class="profile-card__name">{profile.name}</h2>
    <p class="profile-card__role text-caption">
      <span data-lang="jp">{profile.role.jp}</span>
      <span data-lang="en">{profile.role.en}</span>
    </p>
    <span class="profile-card__rule" aria-hidden="true"></span>
    <p class="profile-card__bio" data-lang="jp">{profile.bio.jp}</p>
    <p class="profile-card__bio" data-lang="en">{profile.bio.en}</p>
    <div class="profile-card__expertise">
      <p class="profile-card__expertise-label">expertise</p>
      <ul class="profile-card__tags" aria-label={`${profile.name} expertise`}>
        {profile.expertise.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </div>
</article>

<style>
  .profile-card {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-22);
    align-items: start;
    padding-right: clamp(0px, 3vw, var(--spacing-33));
  }

  .profile-card__image {
    width: 100%;
    height: clamp(280px, 27vw, 312px);
    aspect-ratio: 1.42;
    object-fit: cover;
    border: 1px solid var(--color-smoke);
  }

  .profile-card__body {
    display: grid;
    gap: var(--spacing-15);
  }

  .profile-card__role,
  .profile-card__bio,
  .profile-card__expertise-label {
    margin: 0;
  }

  .profile-card__role {
    color: var(--color-ink);
  }

  .profile-card__name {
    margin: 0;
    font-family: var(--font-te-40);
    font-size: var(--text-heading);
    font-weight: var(--font-weight-thin);
    line-height: var(--leading-heading);
  }

  .profile-card__bio {
    max-width: 34em;
    font-size: var(--text-caption);
    line-height: var(--leading-caption);
    white-space: pre-line;
  }

  .profile-card__rule {
    width: 42px;
    height: 1px;
    background: var(--color-ink);
  }

  .profile-card__expertise {
    display: grid;
    gap: var(--spacing-15);
    margin-top: var(--spacing-15);
    font-size: var(--text-caption);
    line-height: var(--leading-caption);
  }

  .profile-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .profile-card__tags li {
    min-height: 30px;
    display: inline-flex;
    align-items: center;
    padding-inline: 15px;
    border: 1px solid var(--color-smoke);
  }

  @media (max-width: 720px) {
    .profile-card {
      padding-right: 0;
    }
  }
</style>
